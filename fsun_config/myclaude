#!/usr/bin/env bash
# myclaude — personal Claude Code companion CLI
# Works on macOS + Ubuntu (zsh/bash)
set -euo pipefail

# ─── resolve paths ───────────────────────────────────────────────────
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

ECC_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ECC_JS="$SCRIPT_DIR/ecc.js"
CLAUDE_HOME="${HOME}/.claude"
MANIFEST="$SCRIPT_DIR/manifest.json"

# ─── colors ──────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  BOLD="\033[1m"
  DIM="\033[2m"
  CYAN="\033[36m"
  GREEN="\033[32m"
  YELLOW="\033[33m"
  MAGENTA="\033[35m"
  BLUE="\033[34m"
  RED="\033[31m"
  RESET="\033[0m"
else
  BOLD="" DIM="" CYAN="" GREEN="" YELLOW="" MAGENTA="" BLUE="" RED="" RESET=""
fi

# ─── helpers ─────────────────────────────────────────────────────────
header()  { printf "\n${BOLD}${CYAN}%s${RESET}\n" "$1"; }
subhead() { printf "  ${BOLD}%s${RESET}\n" "$1"; }
item()    { printf "  ${GREEN}%-28s${RESET} %s\n" "$1" "$2"; }
dimitem() { printf "  ${DIM}%-28s %s${RESET}\n" "$1" "$2"; }
detail()  { printf "    ${DIM}%s${RESET}\n" "$1"; }
warn()    { printf "  ${YELLOW}%s${RESET}\n" "$1"; }

# Extract first meaningful sentence from a markdown file (skip frontmatter, headings, code)
extract_summary() {
  local file="$1" max="${2:-120}"
  awk '
    BEGIN { in_front=0; in_code=0; found=0 }
    /^---$/ && !in_front && !found { in_front=1; next }
    /^---$/ && in_front  { in_front=0; next }
    in_front { next }
    /^```/ { in_code=!in_code; next }
    in_code { next }
    /^$/ { next }
    /^#/ { next }
    /^>/ { sub(/^> */, ""); if (!found && length > 10 && !/extends/) { print; found=1; next } }
    /^\|/ { next }
    /^- \*\*/ { next }
    /^[A-Z][a-z]/ {
      if (!found) { print; found=1 }
    }
  ' "$file" 2>/dev/null | head -1 | cut -c1-"$max"
}

# Hardcoded brief descriptions for common rules (better than auto-extract)
rule_brief() {
  case "$1" in
    agents)              echo "How agents are orchestrated and delegated to" ;;
    code-review)         echo "Quality, security, and maintainability review standards" ;;
    coding-style)        echo "Immutability, naming, error handling, input validation" ;;
    development-workflow) echo "Feature pipeline: research, plan, TDD, review, commit" ;;
    git-workflow)        echo "Conventional commits, branching, PR workflow" ;;
    hooks)               echo "PreToolUse, PostToolUse, Stop hook types and patterns" ;;
    patterns)            echo "Skeleton projects, repository pattern, common structures" ;;
    performance)         echo "Model selection, token budgets, caching strategies" ;;
    security)            echo "No secrets in code, input validation, SQL/XSS prevention" ;;
    testing)             echo "80% coverage minimum, unit/integration/E2E required" ;;
    *)                   extract_summary "$2" 90 ;;
  esac
}

# ─── status (default) ────────────────────────────────────────────────
cmd_status_dashboard() {
  printf "${BOLD}${CYAN}"
  cat <<'ART'
  ┌─────────────────────────────────────┐
  │  myclaude — Claude Code companion   │
  └─────────────────────────────────────┘
ART
  printf "${RESET}"

  # ── Counts (split by context cost) ──
  header "CONFIGURED  (managed by myclaude → ~/.claude/)"
  _count() { find "$CLAUDE_HOME/$1" -type f -name "*.md" 2>/dev/null | wc -l | tr -d ' '; }
  local r a c s
  r=$(_count rules); a=$(_count agents); c=$(_count commands); s=$(_count skills)

  printf "\n  ${BOLD}ALWAYS-ON${RESET} ${DIM}— loaded into every conversation${RESET}\n"
  printf "  ${GREEN}%-12s${RESET} %-3s ${DIM}the only \"follow this\" set${RESET}\n" "rules" "$r"

  printf "\n  ${BOLD}ON-DEMAND${RESET} ${DIM}— zero context cost until invoked${RESET}\n"
  printf "  ${GREEN}%-12s${RESET} %-3s ${DIM}loads only when a task matches${RESET}\n" "skills" "$s"
  printf "  ${GREEN}%-12s${RESET} %-3s ${DIM}loads only when Claude delegates${RESET}\n" "agents" "$a"
  printf "  ${GREEN}%-12s${RESET} %-3s ${DIM}loads only when you type /cmd${RESET}\n" "commands" "$c"

  printf "\n  ${BOLD}%-12s %s${RESET} ${DIM}(rules always-on; rest is a lazy library)${RESET}\n" \
    "total" "$((r + a + c + s))"

  # ── Hooks ──
  header "HOOKS WIRED  (~/.claude/settings.json)"
  local settings="$CLAUDE_HOME/settings.json"
  if [[ -f "$settings" ]]; then
    local phase_counts
    # Count hooks per phase and extract key ones
    for phase in SessionStart PreToolUse PostToolUse Stop SessionEnd PreCompact PostToolUseFailure; do
      local count
      count=$(node -e "
        const s = require('$settings');
        const h = (s.hooks && s.hooks['$phase']) || [];
        console.log(h.length);
      " 2>/dev/null || echo "0")
      [[ "$count" == "0" ]] && continue
      printf "  ${GREEN}%-20s${RESET} %s hooks\n" "$phase" "$count"
    done

    # Highlight key session hooks
    printf "\n"
    subhead "Session lifecycle:"
    local session_hooks=("session:start|SessionStart|auto-loads previous context" "stop:session-end|Stop|auto-saves session after each response" "session:end:marker|SessionEnd|session end lifecycle marker")
    for entry in "${session_hooks[@]}"; do
      local id phase desc
      IFS='|' read -r id phase desc <<< "$entry"
      local found
      found=$(node -e "
        const s = require('$settings');
        const hooks = (s.hooks && s.hooks['$phase']) || [];
        const match = hooks.find(h => h.id === '$id');
        console.log(match ? 'active' : 'missing');
      " 2>/dev/null || echo "unknown")
      if [[ "$found" == "active" ]]; then
        printf "    ${GREEN}%-26s${RESET} %s\n" "$id" "$desc"
      else
        printf "    ${RED}%-26s${RESET} ${DIM}NOT WIRED — %s${RESET}\n" "$id" "$desc"
      fi
    done
  else
    warn "No settings.json found"
  fi

  # ── Sessions ──
  header "SESSIONS"
  local session_dir="$CLAUDE_HOME/session-data"
  if [[ -d "$session_dir" ]]; then
    local scount
    scount=$(find "$session_dir" -name "*-session.tmp" -type f 2>/dev/null | wc -l | tr -d ' ')
    printf "  ${GREEN}%-20s${RESET} %s saved sessions\n" "session-data/" "$scount"
    # Show most recent 3
    if [[ "$scount" -gt 0 ]]; then
      printf "\n"
      subhead "Recent:"
      find "$session_dir" -name "*-session.tmp" -type f -print0 2>/dev/null \
        | xargs -0 ls -t 2>/dev/null | head -3 | while read -r sf; do
          local sname proj worktree
          sname=$(basename "$sf" .tmp)
          proj=$(awk '/^\*\*Project:\*\*/{sub(/.*\*\* */, ""); print; exit}' "$sf" 2>/dev/null)
          worktree=$(awk '/^\*\*Worktree:\*\*/{sub(/.*\*\* */, ""); print; exit}' "$sf" 2>/dev/null)
          worktree="${worktree/$HOME/\~}"
          if [[ -n "$proj" ]]; then
            printf "    ${DIM}%s${RESET}  ${GREEN}%s${RESET}  %s\n" "$sname" "$proj" "$worktree"
          else
            printf "    ${DIM}%s${RESET}\n" "$sname"
          fi
        done
    fi
  else
    printf "  ${DIM}No sessions yet (will auto-save after first Claude session)${RESET}\n"
  fi

  # ── Quick ref ──
  printf "\n${DIM}  Type ${RESET}${GREEN}myclaude help${RESET}${DIM} for all commands${RESET}\n\n"
}

