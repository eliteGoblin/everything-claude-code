#!/usr/bin/env bash
# myclaude — personal Claude Code companion CLI
# Works on macOS + Ubuntu (zsh/bash)
set -euo pipefail

# ─── resolve paths ───────────────────────────────────────────────────
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

ECC_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ECC_JS="$SCRIPT_DIR/ecc.js"
CLAUDE_HOME="${HOME}/.claude"
MANIFEST="$SCRIPT_DIR/manifest.json"

# ─── colors ──────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  BOLD="\033[1m"
  DIM="\033[2m"
  CYAN="\033[36m"
  GREEN="\033[32m"
  YELLOW="\033[33m"
  MAGENTA="\033[35m"
  BLUE="\033[34m"
  RED="\033[31m"
  RESET="\033[0m"
else
  BOLD="" DIM="" CYAN="" GREEN="" YELLOW="" MAGENTA="" BLUE="" RED="" RESET=""
fi

# ─── helpers ─────────────────────────────────────────────────────────
header()  { printf "\n${BOLD}${CYAN}%s${RESET}\n" "$1"; }
subhead() { printf "  ${BOLD}%s${RESET}\n" "$1"; }
item()    { printf "  ${GREEN}%-28s${RESET} %s\n" "$1" "$2"; }
dimitem() { printf "  ${DIM}%-28s %s${RESET}\n" "$1" "$2"; }
detail()  { printf "    ${DIM}%s${RESET}\n" "$1"; }
warn()    { printf "  ${YELLOW}%s${RESET}\n" "$1"; }

# Extract first meaningful sentence from a markdown file (skip frontmatter, headings, code)
extract_summary() {
  local file="$1" max="${2:-120}"
  awk '
    BEGIN { in_front=0; in_code=0; found=0 }
    /^---$/ && !in_front && !found { in_front=1; next }
    /^---$/ && in_front  { in_front=0; next }
    in_front { next }
    /^```/ { in_code=!in_code; next }
    in_code { next }
    /^$/ { next }
    /^#/ { next }
    /^>/ { sub(/^> */, ""); if (!found && length > 10 && !/extends/) { print; found=1; next } }
    /^\|/ { next }
    /^- \*\*/ { next }
    /^[A-Z][a-z]/ {
      if (!found) { print; found=1 }
    }
  ' "$file" 2>/dev/null | head -1 | cut -c1-"$max"
}

# Hardcoded brief descriptions for common rules (better than auto-extract)
rule_brief() {
  case "$1" in
    agents)              echo "How agents are orchestrated and delegated to" ;;
    code-review)         echo "Quality, security, and maintainability review standards" ;;
    coding-style)        echo "Immutability, naming, error handling, input validation" ;;
    development-workflow) echo "Feature pipeline: research, plan, TDD, review, commit" ;;
    git-workflow)        echo "Conventional commits, branching, PR workflow" ;;
    hooks)               echo "PreToolUse, PostToolUse, Stop hook types and patterns" ;;
    patterns)            echo "Skeleton projects, repository pattern, common structures" ;;
    performance)         echo "Model selection, token budgets, caching strategies" ;;
    security)            echo "No secrets in code, input validation, SQL/XSS prevention" ;;
    testing)             echo "80% coverage minimum, unit/integration/E2E required" ;;
    *)                   extract_summary "$2" 90 ;;
  esac
}

# ─── cheatsheet (default) ───────────────────────────────────────────
cmd_cheatsheet() {
  printf "${BOLD}${CYAN}"
  cat <<'ART'
  ┌─────────────────────────────────────┐
  │  myclaude — Claude Code companion   │
  └─────────────────────────────────────┘
ART
  printf "${RESET}"

  # ── Slash commands ──
  header "COMMANDS  (type in Claude Code)"
  local cmd_dir="$CLAUDE_HOME/commands"
  if [[ -d "$cmd_dir" ]]; then
    # Read description from frontmatter
    for f in "$cmd_dir"/*.md; do
      [[ -f "$f" ]] || continue
      local name
      name=$(basename "$f" .md)
      local desc
      desc=$(awk '/^description:/{sub(/^description: */, ""); print; exit}' "$f" 2>/dev/null)
      [[ -z "$desc" ]] && desc=$(awk '/^#/{sub(/^#+ */, ""); print; exit}' "$f" 2>/dev/null)
      case "$name" in
        plan|tdd|build-fix|code-review|e2e|verify)
          item "/$name" "${desc:0:60}" ;;
        save-session|resume-session|sessions)
          item "/$name" "${desc:0:60}" ;;
        *)
          dimitem "/$name" "${desc:0:55}" ;;
      esac
    done
  else
    warn "No commands installed"
  fi

  # ── Agents ──
  header "AGENTS  (auto-delegated by Claude)"
  local agent_dir="$CLAUDE_HOME/agents"
  if [[ -d "$agent_dir" ]]; then
    for f in "$agent_dir"/*.md; do
      [[ -f "$f" ]] || continue
      local name model desc_a
      name=$(basename "$f" .md)
      model=$(awk '/^model:/{print $2; exit}' "$f" 2>/dev/null)
      desc_a=$(awk '/^description:/{sub(/^description: */, ""); print; exit}' "$f" 2>/dev/null)
      local model_color="$YELLOW"
      [[ "$model" == "opus" ]] && model_color="$MAGENTA"
      printf "  ${GREEN}%-28s${RESET} ${model_color}%-6s${RESET} %s\n" "$name" "$model" "${desc_a:0:45}"
    done
  else
    warn "No agents installed"
  fi

  # ── Skills ──
  header "SKILLS  (loaded when relevant)"
  local skill_dir="$CLAUDE_HOME/skills"
  if [[ -d "$skill_dir" ]]; then
    for d in "$skill_dir"/*/; do
      [[ -d "$d" ]] || continue
      local name
      name=$(basename "$d")
      local desc_s=""
      if [[ -f "$d/SKILL.md" ]]; then
        desc_s=$(awk '/^#/{sub(/^#+ */, ""); print; exit}' "$d/SKILL.md" 2>/dev/null)
      fi
      item "$name" "${desc_s:0:55}"
    done
  else
    warn "No skills installed"
  fi

  # ── Rules ──
  header "RULES  (always loaded into context)"
  if [[ -d "$CLAUDE_HOME/rules" ]]; then
    for d in "$CLAUDE_HOME/rules"/*/; do
      [[ -d "$d" ]] || continue
      local name count
      name=$(basename "$d")
      count=$(find "$d" -name "*.md" -type f | wc -l | tr -d ' ')
      item "$name/" "${count} rules"
    done
  else
    warn "No rules installed"
  fi

  # ── Quick reference ──
  header "QUICK REFERENCE"
  printf "  ${BOLD}Daily workflow:${RESET}\n"
  printf "    ${GREEN}/plan${RESET} <requirements>   ${DIM}→ plan before coding${RESET}\n"
  printf "    ${GREEN}/tdd${RESET}  <feature>        ${DIM}→ test-driven development${RESET}\n"
  printf "    ${GREEN}/build-fix${RESET}             ${DIM}→ auto-fix build errors${RESET}\n"
  printf "    ${GREEN}/code-review${RESET} [PR#]     ${DIM}→ review changes or PR${RESET}\n"
  printf "    ${GREEN}/verify${RESET}                ${DIM}→ pre-ship checks${RESET}\n"
  printf "\n  ${BOLD}Inspect (add --verbose / -v for details):${RESET}\n"
  printf "    ${GREEN}myclaude rules${RESET}         ${DIM}→ list rules (--verbose: what each covers)${RESET}\n"
  printf "    ${GREEN}myclaude skills${RESET}        ${DIM}→ list skills (--verbose: sections & value)${RESET}\n"
  printf "    ${GREEN}myclaude commands${RESET}      ${DIM}→ list commands (--verbose: full descriptions)${RESET}\n"
  printf "    ${GREEN}myclaude agents${RESET}        ${DIM}→ list agents & models${RESET}\n"
  printf "    ${GREEN}myclaude counts${RESET}        ${DIM}→ file counts${RESET}\n"
  printf "\n  ${BOLD}Manage:${RESET}\n"
  printf "    ${GREEN}myclaude pick${RESET} <path>   ${DIM}→ add upstream file/dir${RESET}\n"
  printf "    ${GREEN}myclaude unpick${RESET} <path> ${DIM}→ remove file/dir${RESET}\n"
  printf "    ${GREEN}myclaude sync${RESET}          ${DIM}→ apply to ~/.claude/${RESET}\n"
  printf "    ${GREEN}myclaude diff${RESET}          ${DIM}→ upstream changes${RESET}\n"
  printf "    ${GREEN}myclaude browse${RESET}        ${DIM}→ all upstream files${RESET}\n"
  printf "    ${GREEN}myclaude own${RESET} <path>    ${DIM}→ create custom file${RESET}\n"
  printf "    ${GREEN}myclaude agents --opus${RESET} ${DIM}→ upgrade all to opus${RESET}\n"
  printf "    ${GREEN}myclaude status${RESET}        ${DIM}→ verify install${RESET}\n"
  printf "    ${GREEN}myclaude install-link${RESET}  ${DIM}→ add to PATH${RESET}\n"
  echo ""
}

# ─── rules subcommand ────────────────────────────────────────────────
cmd_rules() {
  local verbose=0
  [[ "${1:-}" == "--verbose" || "${1:-}" == "-v" ]] && verbose=1

  header "RULES  (always loaded into context)"
  if [[ ! -d "$CLAUDE_HOME/rules" ]]; then
    warn "No rules installed"; return
  fi

  for d in "$CLAUDE_HOME/rules"/*/; do
    [[ -d "$d" ]] || continue
    local group
    group=$(basename "$d")
    local count
    count=$(find "$d" -name "*.md" -type f | wc -l | tr -d ' ')
    printf "  ${BOLD}${GREEN}%s/${RESET}  ${DIM}(%s files)${RESET}\n" "$group" "$count"

    if [[ $verbose -eq 1 ]]; then
      for f in "$d"/*.md; do
        [[ -f "$f" ]] || continue
        local fname summary
        fname=$(basename "$f" .md)
        summary=$(rule_brief "$fname" "$f")
        if [[ -z "$summary" || "$summary" == *"extends"* ]]; then
          # Use group + common description as fallback
          summary=$(rule_brief "$fname" "")
          [[ -z "$summary" ]] && summary="Extends common/$fname for $group"
        fi
        printf "    ${GREEN}%-22s${RESET} %s\n" "$fname" "$summary"
      done
      echo ""
    fi
  done

  if [[ $verbose -eq 0 ]]; then
    printf "\n  ${DIM}Use ${RESET}${GREEN}myclaude rules --verbose${RESET}${DIM} to see what each rule covers${RESET}\n"
  fi
  echo ""
}

# ─── skills subcommand ──────────────────────────────────────────────
cmd_skills() {
  local verbose=0
  [[ "${1:-}" == "--verbose" || "${1:-}" == "-v" ]] && verbose=1

  header "SKILLS  (loaded when relevant)"
  local skill_dir="$CLAUDE_HOME/skills"
  if [[ ! -d "$skill_dir" ]]; then
    warn "No skills installed"; return
  fi

  for d in "$skill_dir"/*/; do
    [[ -d "$d" ]] || continue
    local name
    name=$(basename "$d")
    local skill_file="$d/SKILL.md"
    [[ -f "$skill_file" ]] || continue

    # Get description from frontmatter
    local desc
    desc=$(awk '/^description:/{sub(/^description: */, ""); print; exit}' "$skill_file" 2>/dev/null)

    if [[ $verbose -eq 1 ]]; then
      printf "  ${BOLD}${GREEN}%s${RESET}\n" "$name"
      if [[ -n "$desc" ]]; then
        printf "    %s\n" "$desc"
      fi
      # Show ## sections as bullet points
      awk '/^## /{sub(/^## */, ""); printf "    - %s\n", $0}' "$skill_file" 2>/dev/null
      echo ""
    else
      item "$name" "${desc:0:60}"
    fi
  done

  if [[ $verbose -eq 0 ]]; then
    printf "\n  ${DIM}Use ${RESET}${GREEN}myclaude skills --verbose${RESET}${DIM} to see what each skill provides${RESET}\n"
  fi
  echo ""
}

# ─── commands subcommand ─────────────────────────────────────────────
cmd_commands() {
  local verbose=0
  [[ "${1:-}" == "--verbose" || "${1:-}" == "-v" ]] && verbose=1

  header "COMMANDS  (type in Claude Code)"
  local cmd_dir="$CLAUDE_HOME/commands"
  if [[ ! -d "$cmd_dir" ]]; then
    warn "No commands installed"; return
  fi

  for f in "$cmd_dir"/*.md; do
    [[ -f "$f" ]] || continue
    local name desc
    name=$(basename "$f" .md)
    desc=$(awk '/^description:/{sub(/^description: */, ""); print; exit}' "$f" 2>/dev/null)
    [[ -z "$desc" ]] && desc=$(awk '/^#/{sub(/^#+ */, ""); print; exit}' "$f" 2>/dev/null)

    if [[ $verbose -eq 1 ]]; then
      printf "  ${BOLD}${GREEN}/%s${RESET}  %s\n" "$name" "${desc:0:70}"
      local summary
      summary=$(extract_summary "$f" 100)
      [[ -n "$summary" ]] && detail "$summary"
      echo ""
    else
      case "$name" in
        plan|tdd|build-fix|code-review|e2e|verify)
          item "/$name" "${desc:0:60}" ;;
        save-session|resume-session|sessions)
          item "/$name" "${desc:0:60}" ;;
        *)
          dimitem "/$name" "${desc:0:55}" ;;
      esac
    fi
  done

  if [[ $verbose -eq 0 ]]; then
    printf "\n  ${DIM}Use ${RESET}${GREEN}myclaude commands --verbose${RESET}${DIM} for details${RESET}\n"
  fi
  echo ""
}

# ─── counts ──────────────────────────────────────────────────────────
cmd_counts() {
  header "INSTALLED FILE COUNTS"
  local total=0
  for kind in rules agents commands skills; do
    local dir="$CLAUDE_HOME/$kind"
    if [[ -d "$dir" ]]; then
      local count
      count=$(find "$dir" -type f | wc -l | tr -d ' ')
      item "$kind/" "$count files"
      total=$((total + count))
    fi
  done
  printf "\n  ${BOLD}Total: %d files${RESET}\n\n" "$total"
}

# ─── install-link ────────────────────────────────────────────────────
cmd_install_link() {
  local bin_dir="${HOME}/.local/bin"
  local link_path="$bin_dir/myclaude"
  local target="$SCRIPT_DIR/myclaude"

  mkdir -p "$bin_dir"

  if [[ -L "$link_path" ]]; then
    local existing
    existing=$(readlink "$link_path")
    if [[ "$existing" == "$target" ]]; then
      printf "${GREEN}Already linked:${RESET} %s -> %s\n" "$link_path" "$target"
      return 0
    fi
    rm "$link_path"
  elif [[ -e "$link_path" ]]; then
    printf "${RED}Error:${RESET} %s exists and is not a symlink. Remove it first.\n" "$link_path"
    return 1
  fi

  ln -s "$target" "$link_path"
  printf "${GREEN}Linked:${RESET} %s -> %s\n" "$link_path" "$target"

  # Check if ~/.local/bin is in PATH
  if [[ ":$PATH:" != *":$bin_dir:"* ]]; then
    printf "\n${YELLOW}~/.local/bin is not in your PATH.${RESET} Add to your shell rc:\n"
    printf "  echo 'export PATH=\"\$HOME/.local/bin:\$PATH\"' >> ~/.zshrc\n"
    printf "  source ~/.zshrc\n"
  else
    printf "\nYou can now run ${GREEN}myclaude${RESET} from anywhere.\n"
  fi
}

# ─── delegates to ecc.js ────────────────────────────────────────────
delegate() {
  if [[ ! -f "$ECC_JS" ]]; then
    printf "${RED}Error:${RESET} %s not found\n" "$ECC_JS"
    exit 1
  fi
  node "$ECC_JS" "$@"
}

# ─── main ────────────────────────────────────────────────────────────
cmd="${1:-}"
shift 2>/dev/null || true

case "$cmd" in
  ""|-h|--help|help|cheatsheet)
    cmd_cheatsheet
    ;;
  rules)
    cmd_rules "$@"
    ;;
  skills)
    cmd_skills "$@"
    ;;
  commands)
    cmd_commands "$@"
    ;;
  counts)
    cmd_counts
    ;;
  install-link)
    cmd_install_link
    ;;
  pick|unpick|sync|diff|agents|own|status|ls)
    delegate "$cmd" "$@"
    ;;
  browse)
    delegate ls upstream "$@"
    ;;
  *)
    printf "${RED}Unknown command:${RESET} %s\n" "$cmd"
    printf "Run ${GREEN}myclaude${RESET} for help.\n"
    exit 1
    ;;
esac
